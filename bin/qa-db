#!/usr/bin/env bash
# qa-db — test result storage for QA agent
# Usage: qa-db <command> [args...]
#
# Commands:
#   init                                    Create/migrate the database
#   record  --scenario S --status S ...     Record a test run
#   history [--scenario S] [--status S]     Query past runs
#   latest  [--scenario S]                  Show most recent run per scenario
#   flaky   [--days N] [--window N]         Show scenarios with mixed pass/fail
#   summary [--days N]                      Pass/fail counts per scenario
#   regression                              Scenarios that newly started failing
#   fixes                                   Scenarios that newly started passing
#   streak  [--min N]                       Scenarios failing N+ consecutive runs
#   blame   <scenario>                      First run where a scenario started failing
#   health  [--window N]                    TestGrid-style status per scenario

set -euo pipefail

DB="${QA_DB:-$(dirname "$0")/../results/qa.db}"

init_db() {
  sqlite3 "$DB" <<'SQL'
CREATE TABLE IF NOT EXISTS runs (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  run_id TEXT NOT NULL,
  scenario TEXT NOT NULL,
  status TEXT NOT NULL CHECK (status IN ('pass', 'fail', 'invalid')),
  duration_s INTEGER,
  assertions_passed INTEGER DEFAULT 0,
  assertions_total INTEGER DEFAULT 0,
  pr_number INTEGER,
  head_sha TEXT,
  notes TEXT,
  results_file TEXT,
  started_at TEXT NOT NULL DEFAULT (datetime('now')),
  created_at TEXT NOT NULL DEFAULT (datetime('now'))
);
CREATE INDEX IF NOT EXISTS idx_runs_scenario ON runs(scenario);
CREATE INDEX IF NOT EXISTS idx_runs_status ON runs(status);
CREATE INDEX IF NOT EXISTS idx_runs_started ON runs(started_at);
SQL
  echo "Database initialized: $DB"
}

CMD=${1:-help}
shift || true

case "$CMD" in
  init)
    init_db
    ;;

  record)
    # Ensure DB exists
    [ -f "$DB" ] || init_db

    SCENARIO="" STATUS="" DURATION="" PASSED="" TOTAL="" PR="" SHA="" NOTES="" RESULTS=""
    RUN_ID=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --run-id) RUN_ID=$2; shift 2 ;;
        --scenario) SCENARIO=$2; shift 2 ;;
        --status) STATUS=$2; shift 2 ;;
        --duration) DURATION=$2; shift 2 ;;
        --passed) PASSED=$2; shift 2 ;;
        --total) TOTAL=$2; shift 2 ;;
        --pr) PR=$2; shift 2 ;;
        --sha) SHA=$2; shift 2 ;;
        --notes) NOTES=$2; shift 2 ;;
        --results-file) RESULTS=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    [ -z "$SCENARIO" ] && { echo "ERROR: --scenario required"; exit 1; }
    [ -z "$STATUS" ] && { echo "ERROR: --status required"; exit 1; }
    [ -z "$RUN_ID" ] && RUN_ID=$(date +%Y%m%d-%H%M%S)

    sqlite3 "$DB" "INSERT INTO runs (run_id, scenario, status, duration_s, assertions_passed, assertions_total, pr_number, head_sha, notes, results_file)
      VALUES ('$RUN_ID', '$SCENARIO', '$STATUS', ${DURATION:-NULL}, ${PASSED:-0}, ${TOTAL:-0}, ${PR:-NULL}, '${SHA:-}', '${NOTES:-}', '${RESULTS:-}');"

    echo "Recorded: $SCENARIO $STATUS (run $RUN_ID)"
    ;;

  history)
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    SCENARIO="" STATUS="" LIMIT=20
    while [[ $# -gt 0 ]]; do
      case $1 in
        --scenario) SCENARIO=$2; shift 2 ;;
        --status) STATUS=$2; shift 2 ;;
        --limit) LIMIT=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    WHERE="1=1"
    [ -n "$SCENARIO" ] && WHERE="$WHERE AND scenario='$SCENARIO'"
    [ -n "$STATUS" ] && WHERE="$WHERE AND status='$STATUS'"

    sqlite3 -header -column "$DB" \
      "SELECT run_id, scenario, status, duration_s || 's' as duration, assertions_passed || '/' || assertions_total as assertions, pr_number as pr, started_at
       FROM runs WHERE $WHERE ORDER BY started_at DESC LIMIT $LIMIT;"
    ;;

  latest)
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    SCENARIO=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --scenario) SCENARIO=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    WHERE=""
    [ -n "$SCENARIO" ] && WHERE="WHERE scenario='$SCENARIO'"

    sqlite3 -header -column "$DB" \
      "SELECT scenario, status, duration_s || 's' as duration, assertions_passed || '/' || assertions_total as assertions, pr_number as pr, started_at
       FROM runs r1 WHERE started_at = (SELECT MAX(started_at) FROM runs r2 WHERE r2.scenario = r1.scenario) $WHERE ORDER BY scenario;"
    ;;

  flaky)
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    DAYS=7
    while [[ $# -gt 0 ]]; do
      case $1 in
        --days) DAYS=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    sqlite3 -header -column "$DB" \
      "SELECT scenario,
              COUNT(*) as total_runs,
              SUM(CASE WHEN status='pass' THEN 1 ELSE 0 END) as passes,
              SUM(CASE WHEN status='fail' THEN 1 ELSE 0 END) as fails,
              ROUND(100.0 * SUM(CASE WHEN status='fail' THEN 1 ELSE 0 END) / COUNT(*), 1) as fail_pct
       FROM runs
       WHERE started_at > datetime('now', '-$DAYS days')
       GROUP BY scenario
       HAVING COUNT(DISTINCT status) > 1
       ORDER BY fail_pct DESC;"
    ;;

  summary)
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    DAYS=7
    while [[ $# -gt 0 ]]; do
      case $1 in
        --days) DAYS=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    sqlite3 -header -column "$DB" \
      "SELECT scenario,
              COUNT(*) as runs,
              SUM(CASE WHEN status='pass' THEN 1 ELSE 0 END) as pass,
              SUM(CASE WHEN status='fail' THEN 1 ELSE 0 END) as fail,
              SUM(CASE WHEN status='invalid' THEN 1 ELSE 0 END) as invalid,
              ROUND(AVG(duration_s), 0) as avg_duration_s
       FROM runs
       WHERE started_at > datetime('now', '-$DAYS days')
       GROUP BY scenario
       ORDER BY scenario;"
    ;;

  regression)
    # Scenarios that PASSED in their second-most-recent run but FAIL in their most recent.
    # Mirrors TestGrid's alert-open logic: a test transitions from green to red.
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }

    sqlite3 -header -column "$DB" <<'SQL'
WITH ranked AS (
  SELECT scenario, status, run_id, started_at, head_sha,
         ROW_NUMBER() OVER (PARTITION BY scenario ORDER BY started_at DESC) AS rn
  FROM runs
  WHERE status IN ('pass', 'fail')
)
SELECT cur.scenario,
       cur.run_id   AS failing_run,
       cur.head_sha AS sha,
       prev.run_id  AS last_passing_run,
       cur.started_at
FROM ranked cur
JOIN ranked prev ON cur.scenario = prev.scenario AND prev.rn = 2
WHERE cur.rn = 1
  AND cur.status  = 'fail'
  AND prev.status = 'pass'
ORDER BY cur.started_at DESC;
SQL
    ;;

  fixes)
    # Scenarios that FAILED in their second-most-recent run but PASS in their most recent.
    # Mirrors TestGrid's alert-close logic (num_passes_to_disable_alert = 1).
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }

    sqlite3 -header -column "$DB" <<'SQL'
WITH ranked AS (
  SELECT scenario, status, run_id, started_at, head_sha,
         ROW_NUMBER() OVER (PARTITION BY scenario ORDER BY started_at DESC) AS rn
  FROM runs
  WHERE status IN ('pass', 'fail')
)
SELECT cur.scenario,
       cur.run_id   AS passing_run,
       cur.head_sha AS sha,
       prev.run_id  AS last_failing_run,
       cur.started_at
FROM ranked cur
JOIN ranked prev ON cur.scenario = prev.scenario AND prev.rn = 2
WHERE cur.rn = 1
  AND cur.status  = 'pass'
  AND prev.status = 'fail'
ORDER BY cur.started_at DESC;
SQL
    ;;

  streak)
    # Scenarios with N+ consecutive recent failures (default 3).
    # Mirrors TestGrid's num_failures_to_alert: consecutive fail count before alerting.
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    MIN_STREAK=3
    while [[ $# -gt 0 ]]; do
      case $1 in
        --min) MIN_STREAK=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    sqlite3 -header -column "$DB" "
WITH numbered AS (
  SELECT scenario, status, run_id, started_at,
         ROW_NUMBER() OVER (PARTITION BY scenario ORDER BY started_at DESC) AS rn
  FROM runs
  WHERE status IN ('pass', 'fail')
),
-- For each scenario, find the rank of the most recent non-fail run
first_break AS (
  SELECT scenario, MIN(rn) AS break_at
  FROM numbered
  WHERE status != 'fail'
  GROUP BY scenario
),
-- Scenarios with no break at all (100% fail)
no_break AS (
  SELECT scenario, MAX(rn) AS total
  FROM numbered
  GROUP BY scenario
  EXCEPT
  SELECT scenario, MAX(rn) FROM numbered WHERE status != 'fail' GROUP BY scenario
),
streaks AS (
  -- Scenarios that have a passing run somewhere: streak = break_at - 1
  SELECT n.scenario,
         fb.break_at - 1 AS consecutive_fails,
         (SELECT run_id FROM numbered n2 WHERE n2.scenario = n.scenario AND n2.rn = fb.break_at - 1) AS first_fail_run,
         (SELECT run_id FROM numbered n3 WHERE n3.scenario = n.scenario AND n3.rn = 1) AS latest_fail_run
  FROM numbered n
  JOIN first_break fb ON n.scenario = fb.scenario
  WHERE n.rn = 1 AND n.status = 'fail'
  GROUP BY n.scenario
  UNION ALL
  -- Scenarios that have NEVER passed: streak = total count
  SELECT nb.scenario,
         nb.total AS consecutive_fails,
         (SELECT run_id FROM numbered n2 WHERE n2.scenario = nb.scenario AND n2.rn = nb.total) AS first_fail_run,
         (SELECT run_id FROM numbered n3 WHERE n3.scenario = nb.scenario AND n3.rn = 1) AS latest_fail_run
  FROM no_break nb
)
SELECT scenario, consecutive_fails, first_fail_run, latest_fail_run
FROM streaks
WHERE consecutive_fails >= $MIN_STREAK
ORDER BY consecutive_fails DESC;
"
    ;;

  blame)
    # Find the first run_id where a currently-failing scenario started its current failure streak.
    # Mirrors TestGrid's AlertInfo.FailBuildId: the build where the current outage began.
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    SCENARIO=""
    while [[ $# -gt 0 ]]; do
      case $1 in
        --scenario) SCENARIO=$2; shift 2 ;;
        -*) shift ;;
        *) SCENARIO=$1; shift ;;
      esac
    done
    [ -z "$SCENARIO" ] && { echo "ERROR: scenario name required"; echo "Usage: qa-db blame <scenario>"; exit 1; }

    sqlite3 -header -column "$DB" "
WITH numbered AS (
  SELECT id, scenario, status, run_id, started_at, head_sha, pr_number, notes,
         ROW_NUMBER() OVER (ORDER BY started_at DESC) AS rn
  FROM runs
  WHERE scenario = '$SCENARIO' AND status IN ('pass', 'fail')
),
last_pass AS (
  SELECT MIN(rn) AS rn FROM numbered WHERE status = 'pass'
)
SELECT n.run_id    AS blame_run,
       n.head_sha  AS sha,
       n.pr_number AS pr,
       n.started_at,
       n.notes,
       (SELECT COUNT(*) FROM numbered WHERE status = 'fail' AND rn < COALESCE((SELECT rn FROM last_pass), 999999)) AS total_fails_in_streak
FROM numbered n
WHERE n.status = 'fail'
  AND n.rn = COALESCE((SELECT rn - 1 FROM last_pass), (SELECT MAX(rn) FROM numbered))
ORDER BY n.started_at ASC
LIMIT 1;
"
    ;;

  health)
    # TestGrid-style per-scenario health status over a sliding window.
    # Classifies each scenario as: PASS, FAIL, FLAKY, or STALE.
    #
    # Algorithm (adapted from TestGrid overallStatus + flipanalyzer):
    #   STALE  — no runs in the window at all
    #   FAIL   — N+ consecutive recent failures (like num_failures_to_alert, default 3)
    #   FLAKY  — mixed pass/fail with flip_rate > 0 (at least one transition)
    #   PASS   — all recent runs pass
    [ -f "$DB" ] || { echo "No database. Run: qa-db init"; exit 1; }
    WINDOW=10
    FAIL_THRESHOLD=3
    while [[ $# -gt 0 ]]; do
      case $1 in
        --window) WINDOW=$2; shift 2 ;;
        --fail-threshold) FAIL_THRESHOLD=$2; shift 2 ;;
        *) shift ;;
      esac
    done

    sqlite3 -header -column "$DB" "
WITH recent AS (
  SELECT scenario, status, started_at,
         ROW_NUMBER() OVER (PARTITION BY scenario ORDER BY started_at DESC) AS rn
  FROM runs
  WHERE status IN ('pass', 'fail')
),
windowed AS (
  SELECT scenario,
         COUNT(*) AS total,
         SUM(CASE WHEN status = 'pass' THEN 1 ELSE 0 END) AS passes,
         SUM(CASE WHEN status = 'fail' THEN 1 ELSE 0 END) AS fails,
         MAX(started_at) AS last_run
  FROM recent
  WHERE rn <= $WINDOW
  GROUP BY scenario
),
-- Count consecutive failures from most recent run (rn=1) backwards
streak AS (
  SELECT r.scenario,
         COALESCE(MIN(CASE WHEN r.status = 'pass' THEN r.rn END) - 1, $WINDOW) AS consec_fails
  FROM recent r
  WHERE r.rn <= $WINDOW
  GROUP BY r.scenario
)
SELECT w.scenario,
       CASE
         WHEN w.last_run < datetime('now', '-7 days') THEN 'STALE'
         WHEN s.consec_fails >= $FAIL_THRESHOLD THEN 'FAIL'
         WHEN w.fails > 0 AND w.passes > 0 THEN 'FLAKY'
         WHEN w.fails = 0 THEN 'PASS'
         ELSE 'FAIL'
       END AS status,
       w.passes || '/' || w.total AS pass_rate,
       s.consec_fails AS recent_streak,
       ROUND(100.0 * w.fails / w.total, 1) AS fail_pct,
       w.last_run
FROM windowed w
JOIN streak s ON w.scenario = s.scenario
ORDER BY
  CASE
    WHEN w.last_run < datetime('now', '-7 days') THEN 3
    WHEN s.consec_fails >= $FAIL_THRESHOLD THEN 0
    WHEN w.fails > 0 AND w.passes > 0 THEN 1
    ELSE 2
  END,
  s.consec_fails DESC;
"
    ;;

  help|*)
    head -12 "$0" | tail -10
    ;;
esac
